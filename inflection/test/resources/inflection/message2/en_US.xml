<!DOCTYPE message2test SYSTEM "message2test.xsd">
<message2test locale="en-US">
    <test>
        <params>
            <param name="object" type="String"><value>lights</value></param>
        </params>
        <source>The {$object} {is :inflect number=$object} on.</source>
        <print>The lights are on.</print>
    </test>
    <test>
        <params>
            <param name="object" type="String"><value>lights</value></param>
        </params>
        <source>{$object :inflect definiteness=definite} {is :inflect number=$object} on.</source>
        <print>the lights are on.</print>
    </test>
    <test>
        <params>
            <param name="object" type="String"><value>light</value></param>
        </params>
        <source>.local $num = {$object :inflect to=number} .match $num
plural {{The {$object} are on}}
* {{The {$object} is on}}
</source>
        <print>The light is on</print>
    </test>
    <test>
        <params>
            <param name="object" type="String"><value>lights</value></param>
        </params>
        <source>.local $num = {$object :inflect to=number} .match $num
plural {{The {$object} are on}}
* {{The {$object} is on}}
</source>
        <print>The lights are on</print>
    </test>
    <test>
        <params>
            <param name="object" type="String"><value>lights on the front porch</value></param>
        </params>
        <source>.local $num = {$object :inflect to=number} .match $num
plural {{The {$object} are on}}
* {{The {$object} is on}}
</source>
        <print>The lights on the front porch are on</print>
    </test>
    <test>
        <params>
            <param name="object" type="String"><value>light on the front porch</value></param>
        </params>
        <source>.local $num = {$object :inflect to=number} .match $num
plural {{The {$object} are on}}
* {{The {$object} is on}}
</source>
        <print>The light on the front porch is on</print>
    </test>
    <test>
        <params>
            <param name="relationship" type="String"><value>brother</value></param>
        </params>
        <source>I didn't find {$relationship :inflect definiteness=indefinite} in your contacts. What is your {$relationship :inflect case=genitive} name?</source>
        <print>I didn't find a brother in your contacts. What is your brother’s name?</print>
    </test>
    <test>
        <params>
            <param name="relationship" type="String"><value>aunt</value></param>
        </params>
        <source>I didn't find {$relationship :inflect definiteness=indefinite} in your contacts. What is your {$relationship :inflect case=genitive} name?</source>
        <print>I didn't find an aunt in your contacts. What is your aunt’s name?</print>
    </test>
    <test>
        <params>
            <param name="oridinalNum" type="Number"><value>4</value></param>
        </params>
        <source>Your {$oridinalNum :numeral withStyle=asWords withVariant=ordinal} meeting has been canceled</source>
        <print>Your fourth meeting has been canceled</print>
    </test>
    <test>
        <params>
            <param name="count" type="Number"><value>4</value></param>
        </params>
        <source>You have {$count :numeral withStyle=asSpokenWords} messages</source>
        <print>You have 4 messages</print>
        <speak>You have four messages</speak>
    </test>
    <test>
        <params>
            <param name="n" type="Number"><value>1</value></param>
            <param name="unit" type="String"><value>day</value></param>
        </params>
        <source>Your meeting is in {$unit :quantify withValue=$n} from now</source>
        <print>Your meeting is in 1 day from now</print>
    </test>
    <test>
        <params>
            <param name="n" type="Number"><value>2</value></param>
            <param name="unit" type="String"><value>day</value></param>
        </params>
        <source>Your meeting is in {$unit :quantify withValue=$n} from now</source>
        <print>Your meeting is in 2 days from now</print>
    </test>
    <test>
        <params>
            <param name="n" type="Number"><value>3</value></param>
            <param name="unit" type="String"><value>church</value></param>
        </params>
        <source>{$unit :quantify withValue=$n} were found nearby</source>
        <print>3 churches were found nearby</print>
    </test>
    <test>
        <params>
            <param name="word" type="String"><value>valid</value></param>
        </params>
        <source>{$word :inflect bogusFeature=value}</source>
        <print error="U_MF_FORMATTING_ERROR"/>
    </test>
    <test>
        <params>
            <param name="word" type="String"><value>valid</value></param>
        </params>
        <source>.local $v = {$word :inflect bogusFeature=value} .match $v
* {{fallback}}
</source>
        <print error="U_MF_SELECTOR_ERROR"/>
    </test>
    <test>
        <params>
            <param name="word" type="String"><value>valid</value></param>
        </params>
        <source>{$word :inflect to=bogus}</source>
        <print>valid</print>
    </test>
    <test>
        <params>
            <param name="word" type="String"><value>valid</value></param>
        </params>
        <source>.local $v = {$word :inflect to=bogus} .match $v
valid {{is valid}}
* {{other}}
</source>
        <print>other</print>
    </test>
    <test>
        <params><param name="p" type="String"><value>her</value></param></params>
        <source>{$p :pronoun gender=masculine}</source>
        <print>his</print>
    </test>
    <test>
        <params><param name="p" type="PronounConcept"><value>theirs</value></param></params>
        <source>{$p :pronoun gender=masculine}</source>
        <print>his</print>
    </test>
    <test>
        <params><param name="p" type="PronounConcept"><value>he</value></param></params>
        <source>{theirs :pronoun gender=$p}</source>
        <print>his</print>
    </test>
    <test>
        <params><param name="p" type="String"><value>she</value></param></params>
        <source>.local $g = {$p :pronoun to=gender} .match $g
feminine {{feminine phrase}}
masculine {{masculine phrase}}
* {{other phrase}}
</source>
        <print>feminine phrase</print>
    </test>
    <test>
        <params><param name="p" type="String"><value>garbage</value></param></params>
        <source>{$p :pronoun}</source>
        <print error="U_MF_FORMATTING_ERROR"/>
    </test>
    <test>
        <params>
            <param name="p" type="String"><value>her</value></param>
            <param name="obj" type="String"><value>cat</value></param>
        </params>
        <source>{$p :pronoun to=gender withReferent=$obj}</source>
        <print error="U_MF_FORMATTING_ERROR"/>
    </test>
    <test>
        <params>
            <param name="np" type="PronounConcept">
                <value constraint="third singular nominative">xe</value>
                <value constraint="third singular accusative">xem</value>
                <value constraint="third singular genitive">xyr</value>
            </param>
        </params>
        <source>{$np :pronoun case=accusative} {$np :pronoun}</source>
        <print>xem xe</print>
    </test>
</message2test>
