<!DOCTYPE message2test SYSTEM "message2test.xsd">
<message2test locale="es-MX">
    <test>
        <params>
            <param name="name" type="String"><value>gato</value></param>
        </params>
        <source>Foo {$name :inflect definiteness=definite number=plural gender=feminine} Bar</source>
        <print>Foo las gatas Bar</print>
    </test>
    <test>
        <params>
            <param name="name" type="String"><value>gato</value></param>
        </params>
        <source>.local $var1 = {$name :inflect to=gender} .local $var2 = {$name :inflect to=number} .match $var1 $var2
masculine 2 {{{$name} is Masculine &amp; 2}}
feminine singular {{{$name} is Feminine &amp; Singular}}
foo 4 {{{$name} is Foo &amp; 4}}
masculine singular {{{$name} is Masculine &amp; Singular}}
hello singular {{{$name} is Hello &amp; Singular}}
* * {{{$name} is other}}
</source>
        <print>gato is Masculine &amp; Singular</print>
    </test>
    <test>
        <params>
            <param name="n" type="Number"><value>1</value></param>
            <param name="unit" type="String"><value>niño</value></param>
        </params>
        <source>Hay {$unit :quantify withValue=$n} en el video</source>
        <print>Hay 1 niño en el video</print>
        <speak>Hay un niño en el video</speak>
    </test>
    <test>
        <params>
            <param name="n" type="Number"><value>1</value></param>
            <param name="unit" type="String"><value>niña</value></param>
        </params>
        <source>Hay {$unit :quantify withValue=$n} en el video</source>
        <print>Hay 1 niña en el video</print>
        <speak>Hay una niña en el video</speak>
    </test>
    <test>
        <params>
            <param name="n" type="Number"><value>3</value></param>
            <param name="unit" type="String"><value>niño</value></param>
        </params>
        <source>Hay {$unit :quantify withValue=$n} en el video</source>
        <print>Hay 3 niños en el video</print>
        <speak>Hay tres niños en el video</speak>
    </test>
    <test>
        <params>
            <param name="words" type="String[]"><value>gato</value><value>gata</value><value>gatos</value><value>gatas</value></param>
        </params>
        <source>¿Te gustan los videos sobre {$words :list withType=and definiteness=definite}?</source>
        <print>¿Te gustan los videos sobre el gato, la gata, los gatos y las gatas?</print>
    </test>
    <test>
        <params>
            <param name="words" type="String[]"><value>gatos</value></param>
        </params>
        <source>¿Te gustan los videos sobre {$words :list withType=and definiteness=definite}?</source>
        <print>¿Te gustan los videos sobre los gatos?</print>
    </test>
    <test>
        <params>
            <param name="words" type="String[]"><value>gatos</value><value>idiomas</value></param>
        </params>
        <source>¿Te gustan los videos sobre {$words :list withType=and}?</source>
        <print>¿Te gustan los videos sobre gatos e idiomas?</print>
    </test>
    <test>
        <params>
            <param name="words" type="String[]"><value>idiomas</value><value>gatos</value></param>
        </params>
        <source>¿Te gustan los videos sobre {$words :list withType=and}?</source>
        <print>¿Te gustan los videos sobre idiomas y gatos?</print>
    </test>
    <test>
        <params>
            <param name="words" type="String[]"><value>gatos</value><value>idiomas</value></param>
        </params>
        <source>¿Te gustan los videos sobre {$words :list withType=or}?</source>
        <print>¿Te gustan los videos sobre gatos o idiomas?</print>
    </test>
    <test>
        <params>
            <param name="words" type="String[]"><value>gatos</value><value>idiomas</value></param>
        </params>
        <source>{$words :list}</source>
        <print>gatosidiomas</print>
    </test>
    <test>
        <params>
            <param name="words" type="String[]"><value>gato</value><value>gata</value><value>gatos</value></param>
        </params>
        <source>{$words :list withItemDelimiter=|, | withBeforeLast=| y | withItemPrefix=|[| withItemSuffix=|]|}</source>
        <print>[gato], [gata] y [gatos]</print>
    </test>
    <test>
        <params>
            <param name="words" type="String[]"><value>gato</value><value>gata</value></param>
        </params>
        <source>{$words :list withType=and withAvoidItemAffixRedundancy=false}</source>
        <print>gato y gata</print>
    </test>
    <test>
        <params>
            <param name="p" type="String"><value>mío</value></param>
            <param name="obj" type="String"><value>casas</value></param>
        </params>
        <source>{$p :pronoun withReferent=$obj}</source>
        <print>mías</print>
    </test>
</message2test>
