<inflectionTest locale="gu">
    <!-- Number Lookup Tests -->
    <!-- FIXME: <test><source>કલાક</source><result number="singular"/></test> -->
    <!-- FIXME: <test><source>કલાકો</source><result number="plural"/></test> -->
    <!-- FIXME: <test><source>ઘર</source><result number="singular"/></test> -->
